{
  "name": "@spacehaat/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/seed/seed.ts",
    "seed:admin": "tsx src/seed/seed-admin.ts",
    "seed:leads": "tsx src/seed/seed-leads.ts",
    "seed:delhi": "python3 src/seed/map-delhi-csv.py && tsx src/seed/seed-delhi-csv.ts",
    "seed:noida-leads": "python3 src/seed/map-noida-csv-leads.py && tsx src/seed/seed-noida-csv-leads.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.8",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^9.31.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
