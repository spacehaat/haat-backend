PORT=8080
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/inventory
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
COOKIE_NAME=spacehaat_token

# Bootstrap admin (created on first boot if no admin exists)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@spacehaat.in
ADMIN_PASSWORD=ChangeMe@12345
ADMIN_PHONE=

# AWS S3 — listing images & proposal PDFs
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_S3_FOLDER=inventory
# Optional: custom public base URL (CloudFront or bucket website URL)
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.ap-south-1.amazonaws.com

# Optional — AI enquiry parsing for Smart Match (rules fallback if unset)
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o-mini
